{

  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",



    "rootDir": "./src",
    "outDir": "./build",

    "types": ["jest","node"],


    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmitOnError": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
  },

  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "Node"
    }
  },

  "include": ["./src"],
  "exclude": ["./node_modules"]
}