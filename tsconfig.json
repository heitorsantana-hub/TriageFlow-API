{

  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "nodenext",
    "moduleResolution": "NodeNext",



    "rootDir": "./src",
    "outDir": "./build",

    "types": ["node"],


    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmitOnError": true,
    "verbatimModuleSyntax": true
  },

  "include": ["./src"],
  "exclude": ["./node_modules"]
}